  "onClick": "{{\n  (() => {\n    // 1. Double-check we actually have a selection\n    if (!appsmith.store.activeRecipeID) {\n      return showAlert(\"No Schematic Selected!\", \"warning\");\n    }\n\n    // 2. Commit the ID (redundant but safe for state persistence)\n    storeValue('activeRecipeID', appsmith.store.activeRecipeID);\n\n    // 3. Clear transient UI states (like the search bar) so the \n    // selector page is fresh when they return\n    resetWidget(\"input_manual\", true);\n\n    // 4. Execute the hand-off\n    navigateTo('Work Page');\n  })()\n}}",
